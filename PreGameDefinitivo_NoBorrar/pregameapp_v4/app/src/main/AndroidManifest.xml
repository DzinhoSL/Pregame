<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.VIBRATE"/>

    <application
        android:allowBackup="true"
        android:label="PreGame"
        android:theme="@style/Theme.PreGame"
        android:supportsRtl="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">

        <!-- Punto de entrada: Login -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity android:name=".RegisterActivity"  android:exported="false"/>
        <activity android:name=".MainActivity"      android:exported="false"/>
        <activity android:name=".ImpostorActivity"  android:exported="false"/>
        <activity android:name=".TruthDareActivity" android:exported="false"/>
        <activity android:name=".ConcursoActivity"  android:exported="false"/>
        <activity android:name=".MimicaActivity"    android:exported="false"/>
        <activity android:name=".CustomQuestionsActivity" android:exported="false"/>

    </application>
</manifest>